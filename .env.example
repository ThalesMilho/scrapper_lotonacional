# ──────────────────────────────────────────────────
#  Lottery Scraper · Environment Variables
# ──────────────────────────────────────────────────

# --- Proxy (optional — leave blank to disable) ---
# Format: http://user:pass@host:port  OR  socks5://host:port
HTTP_PROXY=
HTTPS_PROXY=

# --- Scraper Runtime ---
SCRAPER_MODE=oneshot          # oneshot | service
SCRAPER_HEADLESS=true
SCRAPER_DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

# --- Schedules (comma-separated HH:MM, Brasília time BRT = UTC-3) ---
# Nacional draws
SCHEDULE_NACIONAL=11:30,14:30,19:30
# ResultadoFacil draws (Boa Sorte, Look, Bicho RJ — every 2h roughly)
SCHEDULE_RESULTADO_FACIL=09:30,11:30,14:30,16:30,18:30,21:30,23:30

# --- Retry ---
SCRAPER_RETRY_INTERVAL_SECONDS=30
SCRAPER_RETRY_MAX_MINUTES=15

# --- MaiorBicho Webhook (outbound) ---
WEBHOOK_URL=https://maiorbichoo.com/api/webhooks/lottery-results
WEBHOOK_API_KEY=change-me-secret-token

# --- FastAPI server (inbound endpoints for maiorbichoo.com) ---
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change-me-api-key

# --- Storage ---
STORAGE_JSON_PATH=data/results.json
STORAGE_CSV_PATH=data/results.csv
